<title>惠聚同事 - 内部优惠导航</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#f6f7f9;color:#222;padding:14px}
.container{max-width:720px;margin:0 auto}
.header{text-align:center;margin:20px 0 26px}
.header h1{font-size:24px;font-weight:700;color:#111}
.header p{font-size:14px;color:#666;margin-top:4px}
.box{background:#fff;border-radius:16px;margin-bottom:18px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,0.06)}
.box-title{font-size:16px;font-weight:600;margin-bottom:14px;padding-left:4px;color:#333}
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
@media(max-width:480px){.grid{grid-template-columns:repeat(3,1fr)}}
.item{text-align:center;display:block;text-decoration:none;color:inherit}
.item img{width:100%;height:56px;object-fit:contain;border-radius:12px;background:#f9f9f9;padding:6px}
.item .name{font-size:12px;margin-top:6px;line-height:1.2}
.footer{text-align:center;font-size:12px;color:#999;padding:20px 0}
</style>
</head>
